---
import { topicSlug, topicClass, imgSrc } from '../lib/taxonomy.js';
const { post } = Astro.props;
const base = import.meta.env.BASE_URL;
const url = (p) => (base + p).replace(/\/{2,}/g, '/');
const d = post.data;
const date = d.pubDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
---
<a class="card" href={url('/posts/' + post.slug)}>
  {d.cover && <img class="thumb" src={imgSrc(base, d.cover)} alt="" loading="lazy" />}
  <div class="meta">
    <span class={`tag ${topicClass(d.topic)}`}>{d.topic}</span>
    <span class="dest">{d.destination}</span>
  </div>
  <h3>{d.title}</h3>
  <p>{d.description}</p>
  <div class="meta foot">
    <span>{d.author}</span><span aria-hidden="true">·</span><span>{date}</span>
  </div>
</a>
<style>
  .thumb { width: 100%; aspect-ratio: 16 / 9; object-fit: cover; border: var(--line); border-radius: var(--radius); margin-bottom: 12px; }
  .foot { color: var(--ink-soft); font-size: .85rem; margin-top: auto; padding-top: 6px; }
</style>
