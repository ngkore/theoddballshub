---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL;
const url = (p) => (base + p).replace(/\/{2,}/g, '/');
---
<Base title="About — The Oddballs" description="Who the Oddballs are and why we write this stuff down.">
  <div class="wrap about">
    <img class="logo" src={url('/images/the-oddballs.png')} alt="The Oddballs — five characters, the logo of the group" />
    <p class="eyebrow">About</p>
    <h1>We're oddballs.</h1>
    <p class="lede">
      We started The Oddballs as a side thing — away from the day jobs — to talk about
      whatever we're actually living through. Moving countries, visas, money, the tools
      we end up relying on, random life lessons that don't fit anywhere else. It turned
      out other people were stuck on the exact same things. So we write it down. Honestly,
      from experience, separating what we know works from what we're still guessing at.
    </p>
    <p class="note">
      Names and faces are deliberately loose — the point is the lessons, not us. Got a
      question, or learned something the hard way yourself? Find us on
      <a href="https://youtube.com/@theoddballshub"> YouTube</a>.
    </p>
  </div>
  <style>
    .about { max-width: 720px; padding-top: 44px; }
    .logo { display: block; width: 100%; max-width: 360px; margin: 0 auto 32px; border: var(--line); border-radius: var(--radius); box-shadow: var(--shadow); }
    .eyebrow { font-family: var(--font-display); text-transform: uppercase; letter-spacing: 1px; font-size: .8rem; color: var(--ink-soft); margin: 0 0 12px; }
    .lede { font-size: 1.15rem; color: var(--ink-soft); margin-bottom: 36px; }
    .note { background: var(--paper); border: var(--line); border-radius: var(--radius); padding: 20px; }
  </style>
</Base>
