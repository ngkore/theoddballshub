---
import '../styles/global.css';
const { title = 'The Oddballs', description = 'Real-life lessons from five oddballs figuring it out abroad.' } = Astro.props;
const base = import.meta.env.BASE_URL;
const url = (p) => (base + p).replace(/\/{2,}/g, '/');

const nav = [
  { label: 'Visa',      href: 'topics/visa' },
  { label: 'Finance',   href: 'topics/finance' },
  { label: 'Tools',     href: 'topics/tools' },
  { label: 'Living',    href: 'topics/living' },
  { label: 'Life Tips', href: 'topics/life-tips' },
  { label: 'Podcast',   href: 'topics/podcast' },
];
const dests = [
  { label: 'Prague',  href: 'destinations/prague' },
  { label: 'France',  href: 'destinations/france' },
  { label: 'General', href: 'destinations/general' },
];
// The five logo colours, used as the little ball-row mark.
const balls = ['var(--green)','var(--orange)','var(--blue-fix)','var(--red)','var(--yellow)'];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>
  <header class="site-head">
    <div class="wrap head-inner">
      <a class="brand" href={url('/')} aria-label="The Oddballs home">
        <span class="balls" aria-hidden="true">
          {balls.map((c) => <span class="ball" style={`background:${c}`}></span>)}
        </span>
        <span class="brand-word">ODDBALLS</span>
      </a>
      <button class="menu-toggle" aria-expanded="false" aria-controls="nav">Menu</button>
      <nav id="nav" class="site-nav">
        <div class="nav-group">
          {nav.map((n) => <a href={url('/' + n.href)}>{n.label}</a>)}
        </div>
        <div class="nav-group nav-dest">
          <span class="nav-label">Where</span>
          {dests.map((d) => <a href={url('/' + d.href)}>{d.label}</a>)}
        </div>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-foot">
    <div class="wrap">
      <span class="balls" aria-hidden="true">
        {balls.map((c) => <span class="ball" style={`background:${c}`}></span>)}
      </span>
      <p>The Oddballs — five people sharing what they learned the hard way.</p>
      <p class="foot-links">
        <a href="https://youtube.com/@theoddballshub">YouTube</a>
        <a href={url('/about')}>About</a>
      </p>
    </div>
  </footer>

  <style>
    .site-head { border-bottom: var(--line); background: var(--cream); position: sticky; top: 0; z-index: 20; }
    .head-inner { display: flex; align-items: center; gap: 18px; padding-top: 14px; padding-bottom: 14px; flex-wrap: wrap; }
    .brand { display: flex; align-items: center; gap: 12px; text-decoration: none; }
    .brand-word { font-family: var(--font-display); font-size: 1.5rem; letter-spacing: -0.5px; }
    .balls { display: inline-flex; gap: 4px; }
    .ball { width: 15px; height: 18px; border-radius: 50%; border: 2.5px solid var(--ink); display: inline-block; }
    .site-nav { margin-left: auto; display: flex; gap: 26px; align-items: center; flex-wrap: wrap; }
    .nav-group { display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }
    .site-nav a { text-decoration: none; font-weight: 700; font-size: .95rem; }
    .site-nav a:hover { text-decoration: underline; text-underline-offset: 4px; }
    .nav-dest { padding-left: 18px; border-left: 2.5px solid var(--ink); }
    .nav-label { font-family: var(--font-display); font-size: .7rem; text-transform: uppercase; opacity: .55; }
    .menu-toggle { display: none; font-family: var(--font-display); font-size: .8rem; text-transform: uppercase; background: var(--ink); color: var(--cream); border: var(--line); border-radius: 100px; padding: .5em 1em; cursor: pointer; }

    .site-foot { border-top: var(--line); margin-top: 70px; padding: 34px 0; background: var(--paper); }
    .site-foot .balls { margin-bottom: 10px; }
    .site-foot p { margin: 4px 0; color: var(--ink-soft); }
    .foot-links { display: flex; gap: 18px; }
    .foot-links a { font-weight: 700; }

    @media (max-width: 820px) {
      .menu-toggle { display: inline-block; margin-left: auto; }
      .site-nav { flex-basis: 100%; flex-direction: column; align-items: flex-start; gap: 12px; display: none; }
      .site-nav.open { display: flex; }
      .nav-dest { padding-left: 0; border-left: none; padding-top: 12px; border-top: 2.5px solid var(--ink); width: 100%; }
    }
  </style>
  <script>
    const t = document.querySelector('.menu-toggle');
    const n = document.getElementById('nav');
    t?.addEventListener('click', () => {
      const open = n.classList.toggle('open');
      t.setAttribute('aria-expanded', String(open));
    });
  </script>
</body>
</html>
